<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.rohtspatil.faaahonfailintellij</id>
    <name>FAAAAH on Fail</name>
    <vendor>rohts-patil</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- JUnit / test framework failure listener -->
        <testStatusListener implementation="com.github.rohtspatil.faaahonfailintellij.listeners.FaaaahTestStatusListener"/>

        <!-- Gradle / Maven external build failure listener -->
        <externalSystemTaskNotificationListener implementation="com.github.rohtspatil.faaahonfailintellij.listeners.FaaaahBuildListener"/>

        <!-- Persistent settings service -->
        <applicationService serviceImplementation="com.github.rohtspatil.faaahonfailintellij.settings.FaaaahSettings"/>

        <!-- Settings UI under Settings → Tools → FAAAAH on Fail -->
        <applicationConfigurable
            instance="com.github.rohtspatil.faaahonfailintellij.settings.FaaaahSettingsConfigurable"
            displayName="FAAAAH on Fail 🎺"
            parentId="tools"/>
    </extensions>
</idea-plugin>
