<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.rohtspatil.faaahonfailintellij</id>
    <name>FAAAAH on Fail</name>
    <vendor>rohts-patil</vendor>

    <description><![CDATA[
        <p>Plays a loud <b>FAAAAH</b> sound whenever something goes wrong in your IDE — so you can't miss a failure even if you look away.</p>
        <p>Detects failures from:</p>
        <ul>
            <li>✅ JUnit / test framework runs</li>
            <li>🔨 Gradle / Maven / external system builds</li>
            <li>▶️ Run configurations (application, scripts, processes)</li>
        </ul>
        <p>Configurable from <b>Settings → Tools → FAAAAH on Fail</b>: enable/disable sound for each failure type independently.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- JUnit / test framework failure listener -->
        <testStatusListener
                implementation="com.github.rohtspatil.faaahonfailintellij.listeners.FaaaahTestStatusListener"/>

        <!-- Gradle / Maven external build failure listener (ExternalSystem framework) -->
        <externalSystemTaskNotificationListener
                implementation="com.github.rohtspatil.faaahonfailintellij.listeners.FaaaahBuildListener"/>

        <!--
            Startup activity that subscribes FaaaahExecutionListener to the PROJECT-level message bus.
            ExecutionManager.EXECUTION_TOPIC is @ProjectLevel - it must be subscribed on the
            project bus (not app bus). A declarative <listeners> block uses the app bus and
            would miss Maven/run process events.
        -->
        <postStartupActivity implementation="com.github.rohtspatil.faaahonfailintellij.startup.FaaaahProjectActivity"/>

        <!-- Persistent settings service -->
        <applicationService serviceImplementation="com.github.rohtspatil.faaahonfailintellij.settings.FaaaahSettings"/>

        <!-- Notification group for the Stop balloon shown during custom sound playback -->
        <notificationGroup id="FAAAAH on Fail" displayType="BALLOON" isLogByDefault="false"/>

        <!-- Settings UI under Settings → Tools → FAAAAH on Fail -->
        <applicationConfigurable
                instance="com.github.rohtspatil.faaahonfailintellij.settings.FaaaahSettingsConfigurable"
                displayName="FAAAAH on Fail"
                parentId="tools"/>

        <!-- Sidebar tool window (right panel, like Maven / Gradle) -->
        <toolWindow id="FAAAAH on Fail"
                    anchor="right"
                    icon="/icons/faaaah.svg"
                    factoryClass="com.github.rohtspatil.faaahonfailintellij.toolWindow.FaaaahToolWindowFactory"/>
    </extensions>

    <actions>
        <!-- Stop sound action: accessible via Find Action (⌘⇧A) and Tools menu -->
        <action id="com.github.rohtspatil.faaahonfailintellij.StopFaaaahSound"
                class="com.github.rohtspatil.faaahonfailintellij.actions.StopFaaaahSoundAction"
                text="🔇 Stop FAAAAH Sound"
                description="Stop any currently playing FAAAAH sound">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
